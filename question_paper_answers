Given a tuple of student marks in five subjects print the count of students who are in different grades. avg>90 O grade avg 80-90 A grade avg 70-80 B grade avg <70 c grade
students = ([95, 92, 90, 93, 96],
            [85, 80, 82, 88, 90],
            [72, 75, 70, 78, 74],
            [60, 65, 68, 62, 66])

o = a = b = c = 0

for s in students:
    avg = sum(s) / 5

    if avg > 90:
        o += 1
    elif avg >= 80:
        a += 1
    elif avg >= 70:
        b += 1
    else:
        c += 1

print("O Grade:", o)
print("A Grade:", a)
print("B Grade:", b)
print("C Grade:", c)
